{
  // ── Proveedor LLM ─────────────────────────────────────────────────────────
  "llm_provider": "lmstudio",        // lmstudio | anthropic | openrouter
  "model": "qwen/qwen3.5-9b",        // nombre del modelo tal como aparece en LM Studio

  // ── LM Studio ─────────────────────────────────────────────────────────────
  "lmstudio_base_url": "http://localhost:1234/v1",  // URL de la API de LM Studio
  "lmstudio_api_mode": "project-mcp",               // project-mcp (recomendado) | native-mcp
  "lmstudio_context_window": 34096,  // ventana de contexto del modelo en tokens
  "lmstudio_web_mcp_port": 8765,     // puerto del servidor MCP local que arranca el scanner
  "lmstudio_fetch_chars": 6000,      // máximo de caracteres por descarga de página web

  // ── Escaneo ───────────────────────────────────────────────────────────────
  "days_ahead": 30,                  // ventana de búsqueda: eventos hasta N días desde hoy
  "max_workers": 4,                  // fuentes procesadas en paralelo (subir con precaución)
  "retry_attempts": 3,               // reintentos por fuente si falla la llamada al LLM
  "retry_backoff": 2,                // multiplicador de espera entre reintentos (1s, 2s, 4s…)
  "cache_retention_days": 90,        // días que se conservan eventos en caché antes de purgarlos

  // ── Notificaciones ────────────────────────────────────────────────────────
  "notification_channel": "teams",   // teams | email
  "max_tokens": 1500,                // máximo de tokens en la respuesta del modelo

  // ── Rutas de archivos (relativas a la raíz del proyecto) ──────────────────
  "known_events_file": "data/known_events.json",
  "prompt_file": "config/prompt.txt",
  "lmstudio_prompt_file": "config/prompt_lmstudio.txt",
  "sources_file": "config/sources.json",
  "report_html_file": "config/templates/report_html.html",

  // Plantillas de notificación
  "email_subject_file": "config/templates/email_subject.txt",
  "email_html_file": "config/templates/email_html.html",
  "email_plain_file": "config/templates/email_plain.txt",
  "teams_title_file": "config/templates/teams_title.txt",
  "teams_body_file": "config/templates/teams_body.txt"
}
