# ── LM Studio ─────────────────────────────────────────────────────────────────
# URL de la API de LM Studio. Cámbiala si corre en otra máquina de la red.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Nombre del modelo tal como aparece en LM Studio
MODEL_NAME=qwen3.5-9b
# Modo de API: project-mcp (requiere plugin MCP de LM Studio) u openai (REST estándar)
LMSTUDIO_API_MODE=project-mcp
# Ventana de contexto del modelo en tokens
LMSTUDIO_CONTEXT_WINDOW=34096
# Llamadas LLM concurrentes (1 = serializar, evita saturar LM Studio)
LMSTUDIO_PARALLEL_CALLS=1
# Timeout por petición al LLM en segundos
LMSTUDIO_REQUEST_TIMEOUT=300
# Máximo de caracteres descargados por página web
LMSTUDIO_FETCH_CHARS=12000
# Máximo de caracteres devueltos al modelo por tool call
LMSTUDIO_TOOL_RESULT_CHARS=6000
# Máximo de rondas de tool calls por fuente
LMSTUDIO_TOOL_ROUNDS=6

# ── Extractor ────────────────────────────────────────────────────────────────
# Subpáginas adicionales a visitar por fuente (0 = solo página principal)
EXTRACTOR_MAX_SUBPAGES=3
# Máximo de caracteres por página enviados al LLM
EXTRACTOR_PER_PAGE_CHARS=6000

# ── Escaneo ───────────────────────────────────────────────────────────────────
# Ventana de búsqueda: eventos en los próximos N días
DAYS_AHEAD=30
# Fuentes procesadas en paralelo (más workers = más rápido pero más carga en LM Studio)
MAX_WORKERS=8
# Reintentos por fuente si falla la llamada al LLM
RETRY_ATTEMPTS=3
# Multiplicador de espera entre reintentos en segundos (1s, 2s, 4s…)
RETRY_BACKOFF=2

# ── Notificaciones ────────────────────────────────────────────────────────────
# Canal de notificación: email | none
NOTIFICATION_CHANNEL=email

# ── Email (Microsoft Graph API) ───────────────────────────────────────────────
# Buzón desde el que se envía (debe ser un usuario real de tu tenant M365)
EMAIL_FROM=tu.nombre@tudominio.com
# Destinatarios separados por comas
EMAIL_TO=destinatario@ejemplo.com,otro@ejemplo.com

# ── Azure AD — App Registration ───────────────────────────────────────────────
# Crea una app en portal.azure.com → Microsoft Entra ID → App registrations
# Permiso necesario: Mail.Send (tipo Application, con admin consent concedido)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# El valor del secreto (no el ID). Está en Certificates & secrets → Client secrets
AZURE_CLIENT_SECRET=tu_client_secret_value

# ── Rutas (opcional, solo si cambias la estructura de directorios) ─────────────
# SOURCES_FILE=config/sources.json
# REPORT_HTML_FILE=config/templates/report_html.html
# EMAIL_SUBJECT_FILE=config/templates/email_subject.txt
# EMAIL_HTML_FILE=config/templates/email_html.html
# EXTRACTOR_SYSTEM_PROMPT_FILE=config/prompts/system_prompt.txt
# EXTRACTOR_USER_PROMPT_FILE=config/prompts/user_prompt.txt
