# ── Notificaciones ────────────────────────────────────────────────────────────
# Canal de notificación: email | none
NOTIFICATION_CHANNEL=email

# ── Email (Microsoft Graph API) ───────────────────────────────────────────────
# Dirección del buzón desde el que se envía (debe ser un usuario de tu tenant M365)
EMAIL_FROM=tu.nombre@tudominio.com

# Destinatarios separados por comas
EMAIL_TO=destinatario@ejemplo.com,otro@ejemplo.com

# ── Azure AD — App Registration ───────────────────────────────────────────────
# Crea una app en https://portal.azure.com → Microsoft Entra ID → App registrations
# Permiso necesario: Mail.Send (tipo Application, con admin consent concedido)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# El valor del secreto (no el ID). Está en Certificates & secrets → Client secrets
AZURE_CLIENT_SECRET=tu_client_secret_value
